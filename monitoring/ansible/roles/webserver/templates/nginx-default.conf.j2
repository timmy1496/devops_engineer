server {
    listen 80 default_server;
    listen [::]:80 default_server;

    server_name _;
    root /var/www/html;
    index index.html index.htm;

    # ─── Main site ─────────────────────────────────────────────────────────
    location / {
        try_files $uri $uri/ =404;
    }

    # ─── Nginx stub_status — для nginx-prometheus-exporter ────────────────
    # Доступ ТІЛЬКИ з localhost (exporter запущений локально)
    location /nginx_status {
        stub_status on;
        access_log  off;
        allow       127.0.0.1;
        allow       {{ monitoring_private_ip }};
        deny        all;
    }

    # ─── Health check endpoint ─────────────────────────────────────────────
    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }
}
