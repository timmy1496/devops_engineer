global:
  scrape_interval:     15s
  evaluation_interval: 15s
  scrape_timeout:      10s
  external_labels:
    monitor: 'monitoring-stack'
    environment: 'dev'

# Alertmanager config (optional, для майбутнього розширення)
# alerting:
#   alertmanagers:
#     - static_configs:
#         - targets: ['alertmanager:9093']

# Rule files (для майбутніх alert rules)
# rule_files:
#   - /etc/prometheus/rules/*.yml

scrape_configs:

  # ─── Prometheus self-monitoring ─────────────────────────────────────────
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
        labels:
          instance: 'monitoring-server'
          environment: 'dev'

  # ─── Node Exporter — Monitoring Server ──────────────────────────────────
  - job_name: 'node-monitoring'
    static_configs:
      - targets: ['{{ monitoring_private_ip }}:9100']
        labels:
          instance: 'monitoring-server'
          role: 'monitoring'
          environment: 'dev'

  # ─── Node Exporter — Web Server ─────────────────────────────────────────
  - job_name: 'node-webserver'
    static_configs:
      - targets: ['{{ webserver_private_ip }}:9100']
        labels:
          instance: 'web-server'
          role: 'webserver'
          environment: 'dev'

  # ─── Nginx metrics (nginx-prometheus-exporter) ──────────────────────────
  - job_name: 'nginx'
    static_configs:
      - targets: ['{{ webserver_private_ip }}:9113']
        labels:
          instance: 'web-server'
          role: 'webserver'
          environment: 'dev'

  # ─── Loki self-monitoring ────────────────────────────────────────────────
  - job_name: 'loki'
    static_configs:
      - targets: ['loki:3100']
        labels:
          instance: 'monitoring-server'
          environment: 'dev'
